# OPTRION Production Environment
# WARNING: Never commit this file with real credentials.
# Use a secret manager (Vault, AWS Secrets Manager, etc.) in production.

APP_NAME=optrion
APP_VERSION=0.1.0
APP_ENV=production

# HTTP Server
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=30s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=30s

# PostgreSQL
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=optrion
DB_SSL_MODE=require
DB_MAX_OPEN_CONNS=50
DB_MAX_IDLE_CONNS=20
DB_CONN_MAX_LIFETIME=30m
DB_CONN_MAX_IDLE_TIME=5m

# Redis
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_RETRIES=3
REDIS_DIAL_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s
REDIS_WRITE_TIMEOUT=3s
REDIS_POOL_SIZE=20

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
